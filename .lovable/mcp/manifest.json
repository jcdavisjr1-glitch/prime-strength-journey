{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ufuvpkqhnsnpngpkcuvk.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "fortystrong-mcp",
      "version": "0.1.0",
      "title": "FortyStrong"
    },
    "tools": [
      {
        "name": "log_workout",
        "title": "Log a workout set",
        "description": "Record a single strength-training set for the signed-in FortyStrong user (exercise, weight, sets, reps, and how it felt).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "exercise_name": {
              "type": "string",
              "minLength": 1,
              "description": "Exercise name, e.g. 'Back squat'."
            },
            "weight": {
              "description": "Weight used, in the user's unit.",
              "type": "number",
              "minimum": 0
            },
            "sets": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "reps": {
              "description": "Target reps for the set.",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "reps_completed": {
              "description": "Reps the user actually completed.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "difficulty": {
              "description": "How the set felt overall.",
              "type": "string",
              "enum": [
                "too_easy",
                "just_right",
                "too_hard"
              ]
            }
          },
          "required": [
            "exercise_name"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_workouts",
        "title": "List recent workouts",
        "description": "Return the signed-in user's most recent strength-training sets, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max sets to return. Default 20.",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "log_walk",
        "title": "Log a walk",
        "description": "Record a walk (duration in minutes on a given date) for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "duration_minutes": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991,
              "description": "Walk length in minutes."
            },
            "logged_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Date walked (YYYY-MM-DD)."
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          },
          "required": [
            "duration_minutes",
            "logged_date"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_walks",
        "title": "List recent walks",
        "description": "Return the signed-in user's walks from the last 60 days, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
